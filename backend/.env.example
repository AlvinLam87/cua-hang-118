PORT=3001
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cuahang118
DB_USER=postgres
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Comma separated. Leave empty to allow all.
CORS_ORIGINS=http://localhost:5173

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME="Cua Hang 118"

# SePay webhook (my.sepay.vn → Webhook → URL: https://<backend>/api/v1/payments/webhook-sepay)
# Cấu hình mã thanh toán tiền tố "DH" trong SePay. Nếu dùng API Key trên SePay, điền vào đây:
# SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key

# Tự xác nhận CK khi khách bấm "Đã chuyển khoản" (chỉ bật khi CHƯA có SePay — không khuyến nghị production)
# BANK_TRANSFER_CLAIM_AUTO_PAID=false
