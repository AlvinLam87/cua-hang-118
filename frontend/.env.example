# Base URL for Backend API. Leave empty for local development (uses proxy).
# Set to your Render/Production URL on Vercel Dashboard.
# Example: VITE_API_BASE_URL=https://cua-hang-118.onrender.com
VITE_API_BASE_URL=

# Socket.io (optional — mặc định dùng VITE_API_BASE_URL)
# VITE_SOCKET_URL=https://cua-hang-118.onrender.com

